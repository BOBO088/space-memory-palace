# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored by the default Next.js config.

# OpenAI: required for real AI explanations. Without it, the API returns
# an offline stub so the rest of the app keeps working.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Supabase: required for cloud sync. The localStorage layer continues to
# work without these; Supabase wiring is enabled once both are set.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Where the "联系我做一个" CTA points. Anything you'd put in an href
# works — mailto:, https://your-site/contact, WeChat qr landing page, etc.
# The share page picks this up at build time.
NEXT_PUBLIC_CONTACT_URL="mailto:hi@example.com?subject=想做一个 3D 空间"
