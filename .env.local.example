# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored by the default Next.js config.

# OpenAI: required for real AI explanations. Without it, the API returns
# an offline stub so the rest of the app keeps working.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Supabase: required for cloud sync. The localStorage layer continues to
# work without these; Supabase wiring is enabled once both are set.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
